            { "id": "dem_expert", "textUa": "Експертний — навчаю інших, склав сертифікацію" }
          ]
        },
        {
          "id": "qual_demining_years",
          "type": "single-choice",
          "required": false,
          "conditionalOn": { "questionId": "qual_demining_yn", "value": true },
          "promptUa": "Стаж у сфері розмінування",
          "options": [
            { "id": "dem_exp_lt1", "textUa": "Менше 1 року" },
            { "id": "dem_exp_1_3", "textUa": "1–3 роки" },
            { "id": "dem_exp_3_7", "textUa": "3–7 років" },
            { "id": "dem_exp_7_15", "textUa": "7–15 років" },
            { "id": "dem_exp_gt15", "textUa": "Понад 15 років" }
          ]
        }
      ]
    },
    {
