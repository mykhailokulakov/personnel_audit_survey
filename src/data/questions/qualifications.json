{
  "sections": [
    {
      "id": "driving",
      "titleUa": "Водійські права",
      "questions": [
        {
          "id": "qual_driving_categories",
          "type": "multi-choice",
          "required": false,
          "promptUa": "Які категорії водійського посвідчення маєте?",
          "note": "Оберіть усі наявні",
          "options": [
            { "id": "cat_B", "textUa": "B — легковий автомобіль" },
            { "id": "cat_C", "textUa": "C — вантажний автомобіль (понад 3,5 т)" },
            { "id": "cat_D", "textUa": "D — автобус (більше 8 пасажирів)" },
            { "id": "cat_E", "textUa": "E — причіп (у поєднанні з B/C/D)" },
            { "id": "cat_A", "textUa": "A — мотоцикл" },
            { "id": "cat_other", "textUa": "Інша категорія" }
          ]
        },
        {
          "id": "qual_driving_experience",
          "type": "single-choice",
          "required": false,
          "conditionalOn": { "questionId": "qual_driving_categories", "notEmpty": true },
          "promptUa": "Загальний стаж водіння",
          "options": [
            { "id": "drv_exp_lt1", "textUa": "Менше 1 року" },
            { "id": "drv_exp_1_3", "textUa": "1–3 роки" },
            { "id": "drv_exp_3_7", "textUa": "3–7 років" },
            { "id": "drv_exp_7_15", "textUa": "7–15 років" },
            { "id": "drv_exp_gt15", "textUa": "Понад 15 років" }
          ]
        }
      ]
    },
    {
      "id": "demining",
      "titleUa": "Розмінування / EOD",
      "questions": [
        {
          "id": "qual_demining_yn",
