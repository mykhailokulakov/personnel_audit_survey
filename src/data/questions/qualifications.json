          "options": [
            { "id": "dro_hrs_lt10", "textUa": "Менше 10 годин" },
            { "id": "dro_hrs_10_50", "textUa": "10–50 годин" },
            { "id": "dro_hrs_50_200", "textUa": "50–200 годин" },
            { "id": "dro_hrs_gt200", "textUa": "Понад 200 годин" }
          ]
